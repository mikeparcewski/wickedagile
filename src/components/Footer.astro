---
/**
 * Footer.astro — site footer. Canonical for the wicked-* family.
 * Markup + CSS ported verbatim. CSS is is:global to preserve the
 * original class names.
 */
---

<!-- FOOTER -->
<footer class="footer">
  <div class="wrap">
    <div class="footer-main">
      <div class="footer-brand-block">
        <p class="kicker">est. on your machine</p>
        <p class="footer-title">wicked<br><span class="footer-accent">good.</span></p>
        <p class="footer-desc">Nine local-first tools for AI-native teams.</p>
        <div class="footer-cta">
          <a href="https://github.com/mikeparcewski" target="_blank" rel="noopener">GitHub ↗</a>
          <a href="https://medium.com/@mike.parcewski" target="_blank" rel="noopener">Medium ↗</a>
        </div>
      </div>
      <div class="footer-cols">
        <div>
          <span class="kicker footer-col-head">Ecosystem</span>
          <ul class="footer-links">
            <li><a href="https://wickedagile.com">wickedagile <span class="ext">↗</span></a></li>
            <li><a href="https://wg.wickedagile.com" target="_blank" rel="noopener">wicked-garden <span class="ext">↗</span></a></li>
            <li><a href="https://wi.wickedagile.com" target="_blank" rel="noopener">wicked-interactive <span class="ext">↗</span></a></li>
            <li><a href="https://we.wickedagile.com" target="_blank" rel="noopener">wicked-estate <span class="ext">↗</span></a></li>
          </ul>
        </div>
        <div>
          <span class="kicker footer-col-head">Knowledge</span>
          <ul class="footer-links">
            <li><a href="https://github.com/mikeparcewski/wicked-brain" target="_blank" rel="noopener">wicked-brain</a></li>
            <li><a href="https://github.com/mikeparcewski/wicked-loom" target="_blank" rel="noopener">wicked-loom</a></li>
            <li><a href="https://github.com/mikeparcewski/wicked-understanding" target="_blank" rel="noopener">wicked-understanding</a></li>
          </ul>
        </div>
        <div>
          <span class="kicker footer-col-head">Quality</span>
          <ul class="footer-links">
            <li><a href="https://github.com/mikeparcewski/wicked-testing" target="_blank" rel="noopener">wicked-testing</a></li>
            <li><a href="https://github.com/mikeparcewski/wicked-vault" target="_blank" rel="noopener">wicked-vault</a></li>
            <li><a href="https://github.com/mikeparcewski/wicked-bus" target="_blank" rel="noopener">wicked-bus</a></li>
          </ul>
        </div>
        <div>
          <span class="kicker footer-col-head">Writing</span>
          <ul class="footer-links">
            <li><a href="https://medium.com/@mike.parcewski" target="_blank" rel="noopener">Medium <span class="ext">blog ↗</span></a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-strip">
      <span>© 2026 · built local-first</span>
      <span>part of the <a href="https://wickedagile.com">wickedagile</a> family</span>
    </div>
  </div>
</footer>

<style is:global>
/* FOOTER */
.footer{border-top:1px solid var(--hairline);color:var(--muted)}
.footer-main{display:flex;flex-direction:row;flex-wrap:nowrap;align-items:flex-start;gap:44px 56px;padding:44px 0 28px}
.footer-brand-block{flex-shrink:0;max-width:230px}
.footer-title{font-family:var(--font-display);font-weight:900;font-stretch:125%;font-size:clamp(2.4rem,3.8vw,3.6rem);line-height:.88;letter-spacing:-.02em;color:var(--ink);margin:10px 0 0}
.footer-accent{color:var(--accent)}
.footer-desc{margin:26px 0 0;font-size:.8rem;color:var(--muted);line-height:1.65;max-width:24ch}
.footer-cta{margin:14px 0 0;display:flex;gap:7px;flex-wrap:wrap}
.footer-cta a{font-family:var(--font-mono);font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-decoration:none;border:1px solid var(--hairline-strong);padding:5px 13px;border-radius:999px;transition:border-color .22s var(--ease),color .22s var(--ease)}
.footer-cta a:hover{border-color:var(--accent);color:var(--accent)}
.footer-cols{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:20px 24px;flex:1;align-self:start;padding-top:2px}
.footer-col-head{margin-bottom:10px;display:block}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:7px}
.footer-links a{color:var(--ink);text-decoration:none;font-family:var(--font-mono);font-size:.72rem;display:inline-flex;align-items:baseline;gap:5px;transition:color .22s var(--ease)}
.footer-links a:hover{color:var(--accent)}
.footer-links .ext{color:var(--faint);font-size:.56rem;letter-spacing:.1em;text-transform:uppercase}
.footer-strip{display:flex;flex-wrap:wrap;gap:8px;justify-content:space-between;align-items:center;padding:14px 0 22px;border-top:1px solid var(--hairline);font-family:var(--font-mono);font-size:.63rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.footer-strip a{color:inherit}
.footer-strip a:hover{color:var(--accent)}

/* RESPONSIVE (footer) */
@media(max-width:960px){
  .footer-main{flex-wrap:wrap}
  .footer-cols{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:600px){
  .footer-cols{grid-template-columns:1fr}
}
</style>
