---
/**
 * Footer.astro — site footer. Canonical for the wicked-* family.
 * Markup + CSS ported verbatim. CSS is is:global to preserve the
 * original class names.
 */
---

<!-- FOOTER -->
<footer class="footer">
  <div class="wrap">
    <div class="footer-main">
      <div class="footer-brand-block">
        <p class="kicker">est. on your machine</p>
        <p class="footer-title">wicked<br><span class="footer-accent">good.</span></p>
        <p class="footer-desc">The plan is a hypothesis. The work is the evidence.</p>
        <div class="footer-cta">
          <a href="https://github.com/mikeparcewski" target="_blank" rel="noopener">GitHub ↗</a>
          <a href="https://medium.com/@mike.parcewski" target="_blank" rel="noopener">Medium ↗</a>
        </div>
      </div>
      <div class="footer-cols">
        <div>
          <span class="kicker footer-col-head">Ecosystem</span>
          <ul class="footer-links">
            <li><a href="https://wi.wickedagile.com" target="_blank" rel="noopener">interactive <span class="ext">↗</span></a></li>
            <li><a href="https://wg.wickedagile.com" target="_blank" rel="noopener">garden <span class="ext">↗</span></a></li>
            <li><a href="https://we.wickedagile.com" target="_blank" rel="noopener">estate <span class="ext">↗</span></a></li>
          </ul>
        </div>
        <div>
          <span class="kicker footer-col-head">Intelligence</span>
          <ul class="footer-links">
            <li><a href="https://github.com/mikeparcewski/wicked-brain" target="_blank" rel="noopener">brain</a></li>
            <li><a href="https://github.com/mikeparcewski/wicked-understanding" target="_blank" rel="noopener">understanding</a></li>
          </ul>
        </div>
        <div>
          <span class="kicker footer-col-head">Quality</span>
          <ul class="footer-links">
            <li><a href="https://github.com/mikeparcewski/wicked-testing" target="_blank" rel="noopener">testing</a></li>
          </ul>
          <span class="kicker footer-col-head" style="margin-top:22px">Compliance</span>
          <ul class="footer-links">
            <li><a href="https://github.com/mikeparcewski/wicked-vault" target="_blank" rel="noopener">vault</a></li>
          </ul>
        </div>
        <div>
          <span class="kicker footer-col-head">Infrastructure</span>
          <ul class="footer-links">
            <li><a href="https://github.com/mikeparcewski/wicked-bus" target="_blank" rel="noopener">bus</a></li>
            <li><a href="https://github.com/mikeparcewski/wicked-loom" target="_blank" rel="noopener">loom</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-strip">
      <span>© 2026 · built local-first</span>
      <span>part of the wickedagile family</span>
    </div>
  </div>
</footer>

<style is:global>
/* FOOTER */
/* footer: +20% size (spacing ×1.2), fonts ×1.5, dark-blue 75% panel */
.footer{border-top:1px solid var(--hairline);color:var(--muted);scroll-snap-align:start;background:rgba(13,17,23,.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}
[data-theme="light"] .footer{background:rgba(24,47,60,.94)}
.footer .kicker{font-size:1.02rem}
.footer-main{display:flex;flex-direction:row;flex-wrap:nowrap;align-items:flex-start;gap:53px 67px;padding:53px 0 34px}
.footer-brand-block{flex-shrink:0;max-width:360px}
.footer-title{font-family:var(--font-display);font-weight:900;font-stretch:125%;font-size:clamp(3.6rem,5.7vw,5.4rem);line-height:.88;letter-spacing:-.02em;color:var(--ink);margin:12px 0 0}
.footer-accent{color:var(--accent)}
.footer-desc{margin:31px 0 0;font-size:1.2rem;color:var(--muted);line-height:1.65;max-width:30ch}
.footer-cta{margin:17px 0 0;display:flex;gap:8px;flex-wrap:wrap}
.footer-cta a{font-family:var(--font-mono);font-size:.9rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-decoration:none;border:1px solid var(--hairline-strong);padding:6px 16px;border-radius:999px;transition:border-color .22s var(--ease),color .22s var(--ease)}
.footer-cta a:hover{border-color:var(--accent);color:var(--accent)}
.footer-cols{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:24px 29px;flex:1;align-self:start;padding-top:2px}
.footer .footer-col-head{margin-bottom:12px;display:block;font-size:.765rem}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:8px}
.footer-links a{color:var(--ink);text-decoration:none;font-family:var(--font-mono);font-size:1.08rem;display:inline-flex;align-items:baseline;gap:6px;transition:color .22s var(--ease)}
.footer-links a:hover{color:var(--accent)}
.footer-links .ext{color:var(--faint);font-size:.84rem;letter-spacing:.1em;text-transform:uppercase}
.footer-strip{display:flex;flex-wrap:wrap;gap:10px;justify-content:space-between;align-items:center;padding:17px 0 26px;border-top:1px solid var(--hairline);font-family:var(--font-mono);font-size:.945rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.footer-strip a{color:inherit}
.footer-strip a:hover{color:var(--accent)}

/* RESPONSIVE (footer) */
@media(max-width:960px){
  .footer-main{flex-wrap:wrap}
  .footer-cols{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:600px){
  .footer-cols{grid-template-columns:1fr}
}
</style>
