---
/**
 * Hero.astro — page-1 hero with the live terminal session.
 * Markup + CSS ported verbatim (CSS is is:global so the terminal
 * script can still find its elements by the original ids/classes).
 * The terminal machinery lives in ../scripts/terminal.js and imports
 * the shared data module.
 */
---

<!-- PAGE 1: HERO -->
<section class="snap-section" id="terminal-section">
  <div class="terminal-section">
    <!-- Row 1: full-width title -->
    <h1 class="hero-title">The best code tells a story.<br>The best stories have <span>architecture.</span></h1>
    <!-- Row 2: 50/50 text + terminal -->
    <div class="hero-row">
      <div class="hero-text-side">
        <p class="hero-text">Most people don't build both.<br>Nobody told them they could.</p>
        <div class="hero-ctas">
          <a class="btn-primary" href="#projects">the work →</a>
          <a class="btn-ghost" href="#content">the writing →</a>
        </div>
      </div>
      <div class="term-window" id="termWindow">
        <div class="term-chrome">
          <span class="dot dot-r"></span><span class="dot dot-y"></span><span class="dot dot-g"></span>
          <span class="term-chrome-title">wickedagile — session</span>
        </div>
        <div class="term-body" id="termBody">
          <div class="term-output" id="termOutput"></div>
          <div class="slash-menu" id="slashMenu" hidden>
            <div class="slash-menu-sep">commands</div>
            <div class="slash-menu-item" data-cmd="articles">articles</div>
            <div class="slash-menu-item" data-cmd="projects">projects</div>
            <div class="slash-menu-item" data-cmd="about">about</div>
          </div>
          <div class="term-prompt-line">
            <span class="term-prompt-char">❯</span>
            <span class="term-cursor-text" id="termCursorText"></span><span class="term-cursor"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
/* ── PAGE 1: HERO ─────────────────────────────────────────────── */
#terminal-section{
  position:relative;
  background-image:radial-gradient(rgba(255,218,25,.028) 1px,transparent 1px);
  background-size:30px 30px
}
#terminal-section::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 55% 80% at 0% 50%,rgba(255,218,25,.055) 0%,transparent 55%)
}
.terminal-section{
  display:flex;flex-direction:column;justify-content:center;gap:36px;
  padding:calc(var(--topbar-h) + 36px) 28px 36px;
  max-width:1240px;margin:0 auto;min-height:100vh;width:100%;
  position:relative;z-index:1
}
/* row 1: full-width title */
.hero-title{
  font-family:var(--font-display);font-weight:900;font-stretch:125%;
  font-size:clamp(3.2rem,6vw,5.8rem);color:var(--ink);
  line-height:.9;letter-spacing:-.03em
}
.hero-title span{color:var(--accent)}
/* row 2: 1/3 text + 2/3 terminal */
.hero-row{display:grid;grid-template-columns:1fr 2fr;gap:44px;align-items:center}
.hero-text-side{display:flex;flex-direction:column;gap:22px}
.hero-text{
  font-size:2.5rem;color:var(--muted);
  line-height:1.24;font-weight:400;letter-spacing:-.02em
}
.hero-kicker{
  font-family:var(--font-mono);font-size:.62rem;letter-spacing:.28em;
  text-transform:uppercase;color:var(--faint);margin-bottom:16px;display:block
}
.hero-ctas{display:flex;gap:12px;flex-wrap:wrap}
.btn-primary{
  display:inline-flex;align-items:center;
  font-family:var(--font-mono);font-size:.72rem;font-weight:700;letter-spacing:.06em;
  padding:11px 22px;border-radius:7px;
  background:var(--accent);color:#0d0f12;
  text-decoration:none;transition:opacity .15s;white-space:nowrap
}
.btn-primary:hover{opacity:.84}
.btn-ghost{
  display:inline-flex;align-items:center;
  font-family:var(--font-mono);font-size:.72rem;font-weight:600;letter-spacing:.06em;
  padding:11px 22px;border-radius:7px;
  border:1px solid rgba(230,237,243,.22);color:var(--ink);
  text-decoration:none;transition:border-color .18s,color .18s;white-space:nowrap
}
.btn-ghost:hover{border-color:rgba(255,218,25,.5);color:var(--accent)}

/* terminal */
.term-window{background:#0d0f12;border-radius:12px;box-shadow:0 32px 80px rgba(0,0,0,.7),0 0 0 1px rgba(255,255,255,.06);overflow:hidden;display:flex;flex-direction:column;width:100%;height:min(42vh,368px)}
.term-chrome{background:#1a1d21;border-bottom:1px solid rgba(255,255,255,.06);height:34px;display:flex;align-items:center;padding:0 12px;gap:6px;flex-shrink:0;position:relative}
.dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.dot-r{background:#ff5f56}.dot-y{background:#ffbd2e}.dot-g{background:#27c93f}
.term-chrome-title{position:absolute;left:50%;transform:translateX(-50%);font-family:var(--font-mono);font-size:.62rem;color:rgba(255,255,255,.24);pointer-events:none}
.term-body{flex:1;overflow-y:auto;padding:12px 16px 8px;font-family:var(--font-mono);font-size:.73rem;line-height:1.72;color:#c9d1d9;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.08) transparent;display:flex;flex-direction:column}
.term-body::-webkit-scrollbar{width:3px}
.term-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px}
.term-output{white-space:pre-wrap;word-break:break-word;flex:1}
.term-output a{color:#79c0ff;text-decoration:underline}
.t-y{color:#ffda19}.t-g{color:#56d364}.t-c{color:#79c0ff}.t-b{font-weight:700}.t-d{opacity:.38}
.term-prompt-line{display:flex;align-items:center;padding-top:2px;flex-shrink:0}
.term-prompt-char{color:#56d364;margin-right:6px;user-select:none;flex-shrink:0}
.term-cursor-text{color:#c9d1d9}
.term-cursor{display:inline-block;width:7px;height:1em;background:#ffda19;vertical-align:text-bottom;animation:blink 1.1s step-end infinite}
@keyframes blink{50%{opacity:0}}
.slash-menu{background:#161b22;border:1px solid rgba(255,255,255,.14);border-radius:8px;padding:4px;margin:3px 0 5px;box-shadow:0 6px 18px rgba(0,0,0,.4);animation:menuIn .12s var(--ease)}
.slash-menu[hidden]{display:none}
@keyframes menuIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.slash-menu-sep{font-family:var(--font-mono);font-size:.56rem;color:rgba(255,255,255,.2);letter-spacing:.15em;text-transform:uppercase;padding:3px 10px 2px}
.slash-menu-item{padding:6px 10px;border-radius:5px;font-family:var(--font-mono);font-size:.7rem;color:rgba(201,209,217,.8);display:flex;align-items:center;gap:6px;cursor:default}
.slash-menu-item.is-sel{background:rgba(255,218,25,.12);color:#ffda19;font-weight:700}
.slash-menu-item.is-sel::before{content:'▸';font-size:.6rem}

/* RESPONSIVE (hero) */
@media(max-width:960px){
  .hero-row{grid-template-columns:1fr;gap:24px}
  .hero-text{max-width:100%}
  .term-window{height:min(40vh,360px)}
}
</style>

<script>
import '../scripts/terminal.js';
</script>
