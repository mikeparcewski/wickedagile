---
/**
 * Shipped.astro — "the ide.": the scroll-driven living IDE split-editor.
 *
 * RECOVERED from the pre-Operability-Board design (commit 23cde21 /
 * component last seen at 6a07545, removed by 80bf77e) and RECONCILED to the
 * current family: seven products in the three canonical strata, honest wave-4
 * positioning, current shared wicked-web chrome + tokens.
 *
 * A tall "track" pins the IDE stage (sticky) and holds SEVEN invisible snap
 * steps; scrolling walks package-by-package. A file-tree of the seven products
 * (three folders = Building Blocks / Utilities / Solutions) drives a DUAL-MODE
 * preview pane:
 *   (a) SITE — the 3 DEPLOYED sites (estate · garden · interactive) drive a
 *       browser-frame via /screenshots/<name>.png (clip-path wipe, RM-gated).
 *   (b) LIB  — the other 4 (brain · bus · testing · crew) have no screenshot,
 *       so they render a faux code-editor "source file" card in the SAME pane.
 *
 * Surface: the editor pane is hardcoded near-black (#0d0f12) in BOTH themes,
 * exactly like the hero terminal — one continuous "editor window". Section
 * GROUND uses theme tokens. Driver: ../scripts/shipped.js. CSS is is:global
 * so shipped.js can query the design's class names/ids. Keeps id="projects"
 * so the hero CTA + terminal /projects anchor still land here.
 */

// Mobile view: the seven marketed products in strata order. The three with a
// `shot` are the deployed sites (rendered with their screenshot); the rest are
// libraries. Honest wave-4 positioning throughout (crew = harness, bus =
// durable fabric, estate = the substrate everything queries).
const packages = [
  // ── building-blocks/ — the bedrock everything queries ─────────────────────
  { name: 'wicked-estate', lang: 'RS', site: 'we.wickedagile.com', href: 'https://we.wickedagile.com', shot: '/screenshots/wicked-estate.png', desc: 'The code graph agents actually trust.' },
  { name: 'wicked-brain', lang: 'JS', href: 'https://github.com/mikeparcewski/wicked-brain', desc: "Your AI agent's memory — markdown and SQLite, no vector DB." },
  { name: 'wicked-bus', lang: 'JS', href: 'https://github.com/mikeparcewski/wicked-bus', desc: 'A durable, tiered event fabric for AI agents and dev tools.' },
  // ── utilities/ — sharpen the loop ─────────────────────────────────────────
  { name: 'wicked-garden', lang: 'JS', site: 'wg.wickedagile.com', href: 'https://wg.wickedagile.com', shot: '/screenshots/wicked-garden.png', desc: "Curated toolkit for what coding agents can't do alone." },
  { name: 'wicked-testing', lang: 'JS', href: 'https://github.com/mikeparcewski/wicked-testing', desc: "A complete QE team for AI coding CLIs that can't self-grade." },
  // ── solutions/ — drive the work ───────────────────────────────────────────
  { name: 'wicked-crew', lang: 'JS', href: 'https://github.com/mikeparcewski/wicked-crew', desc: 'The harness for your agent harnesses.' },
  { name: 'wicked-interactive', lang: 'JS', site: 'wi.wickedagile.com', href: 'https://wi.wickedagile.com', shot: '/screenshots/wicked-interactive.png', desc: 'Describe it, watch it build in your browser, ship it.' },
];
---

<!-- ════════════════════════════════════════════════════════════════
     SHIPPED — THE LIVING IDE split-editor (tree-only, dual-mode preview)
     the ide. — a file-tree of the seven products (3 folders = the three
     strata) drives a dual-mode preview pane: browser-frame for the 3
     deployed sites, faux code-editor for the 4 libraries.
     ════════════════════════════════════════════════════════════════ -->
<section class="zoneB-section" id="projects">
  <div class="ide-track">
    <div class="ide-stage">
  <div class="zone-inner">
    <div class="zone-head">
      <span class="zone-kicker">WORKSPACE · 7 PACKAGES · 3 DEPLOYED</span>
      <h2 class="zone-title">the ide.</h2>
    </div>

    <div class="editor-pane" id="workspacePane">
      <div class="ide-chrome">
        <span class="dot dot-r"></span><span class="dot dot-y"></span><span class="dot dot-g"></span>
        <span class="ide-chrome-title">wicked.code-workspace — the family</span>
      </div>

      <div class="split-editor">
        <!-- LEFT: EXPLORER tree (the seven products, THREE strata folders) -->
        <aside class="ide-explorer" aria-label="Package explorer">
          <div class="explorer-head"><span>the family.</span><span class="ws">wicked.code-workspace</span></div>
          <p class="tree-root-comment"># AI is an org problem, not a model problem.</p>

          <!-- building-blocks/ — wine — the bedrock everything queries -->
          <div class="tree-folder" data-cat="blocks" id="folder-blocks">
            <button class="folder-row" type="button" aria-expanded="true" aria-controls="children-blocks">
              <span class="caret" aria-hidden="true">▾</span><span class="fname--blocks">building-blocks/</span>
            </button>
            <div class="folder-children" id="children-blocks" role="group">
              <a class="tree-leaf" href="https://we.wickedagile.com" data-idx="0" data-mode="site" data-preview="2">
                <span class="leaf-line"><span class="leaf-glyph" aria-hidden="true">RS</span><span class="leaf-name">wicked-estate.rs</span><span class="leaf-tag">crate·MIT·we.wickedagile.com</span></span>
                <span class="leaf-desc">// The code graph agents actually trust.</span>
              </a>
              <a class="tree-leaf" href="https://github.com/mikeparcewski/wicked-brain" target="_blank" rel="noopener" data-idx="1" data-mode="lib" data-lib="wicked-brain">
                <span class="leaf-line"><span class="leaf-glyph" aria-hidden="true">JS</span><span class="leaf-name">wicked-brain.js</span><span class="leaf-tag">npm·MIT</span></span>
                <span class="leaf-desc">// Your AI agent's memory — markdown and SQLite, no vector DB.</span>
              </a>
              <a class="tree-leaf" href="https://github.com/mikeparcewski/wicked-bus" target="_blank" rel="noopener" data-idx="2" data-mode="lib" data-lib="wicked-bus">
                <span class="leaf-line"><span class="leaf-glyph" aria-hidden="true">JS</span><span class="leaf-name">wicked-bus.js</span><span class="leaf-tag">npm·MIT</span></span>
                <span class="leaf-desc">// A durable, tiered event fabric for AI agents and dev tools.</span>
              </a>
            </div>
          </div>

          <!-- utilities/ — blue — sharpen the loop -->
          <div class="tree-folder is-collapsed" data-cat="utilities" id="folder-utilities">
            <button class="folder-row" type="button" aria-expanded="false" aria-controls="children-utilities">
              <span class="caret" aria-hidden="true">▾</span><span class="fname--utilities">utilities/</span>
            </button>
            <div class="folder-children" id="children-utilities" role="group">
              <a class="tree-leaf" href="https://wg.wickedagile.com" data-idx="3" data-mode="site" data-preview="1">
                <span class="leaf-line"><span class="leaf-glyph" aria-hidden="true">JS</span><span class="leaf-name">wicked-garden.js</span><span class="leaf-tag">npm·MIT·wg.wickedagile.com</span></span>
                <span class="leaf-desc">// Curated toolkit for what coding agents can't do alone.</span>
              </a>
              <a class="tree-leaf" href="https://github.com/mikeparcewski/wicked-testing" target="_blank" rel="noopener" data-idx="4" data-mode="lib" data-lib="wicked-testing">
                <span class="leaf-line"><span class="leaf-glyph" aria-hidden="true">JS</span><span class="leaf-name">wicked-testing.js</span><span class="leaf-tag">npm·MIT</span></span>
                <span class="leaf-desc">// A complete QE team for AI coding CLIs that can't self-grade.</span>
              </a>
            </div>
          </div>

          <!-- solutions/ — signal yellow — drive the work -->
          <div class="tree-folder is-collapsed" data-cat="solutions" id="folder-solutions">
            <button class="folder-row" type="button" aria-expanded="false" aria-controls="children-solutions">
              <span class="caret" aria-hidden="true">▾</span><span class="fname--solutions">solutions/</span>
            </button>
            <div class="folder-children" id="children-solutions" role="group">
              <a class="tree-leaf" href="https://github.com/mikeparcewski/wicked-crew" target="_blank" rel="noopener" data-idx="5" data-mode="lib" data-lib="wicked-crew">
                <span class="leaf-line"><span class="leaf-glyph" aria-hidden="true">JS</span><span class="leaf-name">wicked-crew.js</span><span class="leaf-tag">npm·MIT</span></span>
                <span class="leaf-desc">// The harness for your agent harnesses.</span>
              </a>
              <a class="tree-leaf" href="https://wi.wickedagile.com" data-idx="6" data-mode="site" data-preview="0">
                <span class="leaf-line"><span class="leaf-glyph" aria-hidden="true">JS</span><span class="leaf-name">wicked-interactive.js</span><span class="leaf-tag">plugin·MIT·wi.wickedagile.com</span></span>
                <span class="leaf-desc">// Describe it, watch it build in your browser, ship it.</span>
              </a>
            </div>
          </div>
        </aside>

        <!-- RIGHT: PREVIEW pane (DUAL-MODE) -->
        <div class="ide-preview" id="idePreview" data-mode="site">
          <div class="preview-tabs" id="previewTabs" role="tablist" aria-label="Shipped site previews">
            <button class="editor-tab" id="editorTab-0" role="tab" data-idx="0" aria-selected="true" aria-controls="previewPanel" tabindex="0">
              <span class="close-dot" aria-hidden="true"></span>wicked-interactive
            </button>
            <button class="editor-tab" id="editorTab-1" role="tab" data-idx="1" aria-selected="false" aria-controls="previewPanel" tabindex="-1">
              <span class="close-dot" aria-hidden="true"></span>wicked-garden
            </button>
            <button class="editor-tab" id="editorTab-2" role="tab" data-idx="2" aria-selected="false" aria-controls="previewPanel" tabindex="-1">
              <span class="close-dot" aria-hidden="true"></span>wicked-estate
            </button>
          </div>

          <div class="preview-stage" id="previewPanel" role="tabpanel" aria-labelledby="editorTab-0">
            <div class="preview-breadcrumb">shipped <span aria-hidden="true">›</span> <b id="crumbName">wicked-interactive</b> <span aria-hidden="true">›</span> preview</div>

            <!-- MODE (a): SITE — browser-frame -->
            <div class="browser-frame" id="browserFrame">
              <div class="browser-chrome">
                <span class="lights" aria-hidden="true"><i></i><i></i><i></i></span>
                <span class="url" id="previewUrl">wi.wickedagile.com</span>
                <span class="live"><span class="pulse" aria-hidden="true"></span>Live</span>
              </div>
              <div class="browser-shot" id="browserShot">
                <div class="shot-bg shot-bg-back"></div>
                <div class="shot-bg shot-bg-front"></div>
              </div>
            </div>

            <!-- MODE (b): LIBRARY — faux code-editor card -->
            <div class="code-card" id="codeCard" hidden aria-hidden="true">
              <div class="code-card-chrome">
                <span class="cc-glyph" aria-hidden="true">JS</span>
                <span class="cc-file" id="codeFile">wicked-brain.js</span>
                <span class="cc-badge">read-only</span>
              </div>
              <div class="code-card-body">
                <pre class="code-block" id="codeBlock"><code></code></pre>
              </div>
            </div>
          </div>

          <div class="preview-readout">
            <div class="readout-desc" id="readoutDesc">Say the thing. Watch it build. Point at what's wrong. Ship.</div>
            <a class="readout-cta" id="readoutCta" href="https://wi.wickedagile.com">Open Preview ↗</a>
          </div>
        </div>
      </div>

      <!-- MOBILE: shipped is just the package list in order; deployed sites show their screenshot -->
      <div class="shipped-mobile">
        {packages.map((p, i) => (
          <a class={`shm-item${p.shot ? ' has-shot' : ''}`} href={p.href} target={p.shot ? '_self' : '_blank'} rel="noopener">
            <div class="shm-row">
              <span class="shm-idx">{String(i + 1).padStart(2, '0')}</span>
              <span class="shm-name">{p.name}</span>
              {p.site
                ? (<span class="shm-badge shm-badge--live"><span class="shm-dot" aria-hidden="true"></span>live</span>)
                : (<span class="shm-badge">{p.lang}</span>)}
            </div>
            {p.shot && (<div class="shm-shot" style={`background-image:url('${p.shot}')`}></div>)}
            <div class="shm-desc">{p.desc}</div>
            {p.site && (<div class="shm-url">{p.site} ↗</div>)}
          </a>
        ))}
      </div>

      <!-- bottom STATUS BAR (workspace, chrome aria-hidden) -->
      <div class="ide-statusbar" aria-hidden="true">
        <span class="sb-left"><span class="sb-branch">⎇ main</span><span>7 packages</span><span>3 deployed</span></span>
        <span class="sb-right"><span id="sbTheme">dark · #0d0f12</span></span>
      </div>
    </div>
  </div>
    </div>
    <div class="ide-steps" aria-hidden="true"><i class="ide-step" data-step="0"></i><i class="ide-step" data-step="1"></i><i class="ide-step" data-step="2"></i><i class="ide-step" data-step="3"></i><i class="ide-step" data-step="4"></i><i class="ide-step" data-step="5"></i><i class="ide-step" data-step="6"></i></div>
  </div>
</section>

<style is:global>
/* ══════════════════════════════════════════════════════════════════
   SHIPPED — THE LIVING IDE split-editor (tree-only, dual-mode preview)
   Reuses #0d0f12 editor black, 12px radius, hero 0 32px 80px shadow.
   ══════════════════════════════════════════════════════════════════ */

/* shared editor body — the "same window" as the hero terminal.
   LIGHT-THEME DECISION (intentional): the editor pane (workspace) is hardcoded
   near-black (#0d0f12) in BOTH themes, exactly like the hero terminal .term-window,
   which is also always #0d0f12 regardless of theme. The conceit is one continuous
   "editor window" — an editor chrome stays dark even in a light OS theme. In
   harbor-blue light theme the section GROUND turns blue (var(--canvas)) while this
   pane stays dark on purpose, so it reads as an inset editor surface, NOT an
   unfinished theme. Do NOT drive its surface from theme tokens. */
.editor-pane{
  background:#0d0f12;border-radius:12px;
  box-shadow:0 32px 80px rgba(0,0,0,.7),0 0 0 1px rgba(255,255,255,.06);
  overflow:hidden;display:flex;flex-direction:column;width:100%;
  font-family:var(--font-mono)
}
.ide-chrome{
  background:#1a1d21;border-bottom:1px solid rgba(255,255,255,.06);
  height:34px;display:flex;align-items:center;padding:0 12px;gap:6px;
  flex-shrink:0;position:relative
}
.ide-chrome .dot{width:11px;height:11px;border-radius:50%;flex-shrink:0}
.ide-chrome .dot-r{background:#ff5f56}.ide-chrome .dot-y{background:#ffbd2e}.ide-chrome .dot-g{background:#27c93f}
.ide-chrome-title{
  position:absolute;left:50%;transform:translateX(-50%);
  font-family:var(--font-mono);font-size:.62rem;color:rgba(255,255,255,.30);
  pointer-events:none;white-space:nowrap;max-width:78%;overflow:hidden;text-overflow:ellipsis
}

/* ── SHIPPED : split-editor workspace ──────────────────────────── */
.zoneB-section{
  border-top:1px solid var(--hairline);
}
/* SCROLL-DRIVEN IDE: a tall track holds 7 invisible snap steps; the IDE stage
   pins (sticky) and scrolling snaps step-by-step, each step = one package. */
.ide-track{position:relative;min-height:calc(7 * 56vh)}
.ide-stage{
  position:sticky;top:var(--topbar-h);z-index:2;
  height:calc(100vh - var(--topbar-h));
  display:flex;flex-direction:column;justify-content:center;
  padding:clamp(14px,2.6vh,30px) 0
}
.ide-steps{position:absolute;inset:0;z-index:1;pointer-events:none}
.ide-step{display:block;height:56vh;scroll-snap-align:start;scroll-snap-stop:always;scroll-margin-top:var(--topbar-h)}
/* title→content gap raised 18px → 33px to match the articles section */
.zone-inner{max-width:1240px;width:100%;margin:0 auto;padding:0 28px;display:flex;flex-direction:column;gap:33px}
.zone-head{display:flex;flex-direction:column;gap:10px}
.zone-kicker{
  font-family:var(--font-mono);font-size:.66rem;letter-spacing:.3em;text-transform:uppercase;
  color:var(--muted);font-weight:500;display:inline-flex;align-items:center;gap:11px
}
.zone-kicker::before{content:'';width:26px;height:1px;background:var(--accent);flex-shrink:0}
.zone-title{
  font-family:var(--font-display);font-weight:900;font-stretch:125%;
  font-size:clamp(2.2rem,3.8vw,3.4rem);color:var(--ink);
  line-height:.93;letter-spacing:-.03em;margin:0
}
.split-editor{display:grid;grid-template-columns:38% 62%;min-height:520px}

/* LEFT — EXPLORER tree */
.ide-explorer{
  border-right:1px solid var(--hairline);padding:14px 12px 16px;
  display:flex;flex-direction:column;gap:2px;overflow:hidden
}
.explorer-head{
  display:flex;align-items:center;justify-content:space-between;gap:8px;
  font-family:var(--font-mono);font-size:.56rem;letter-spacing:.18em;text-transform:uppercase;
  color:var(--muted);padding:2px 6px 10px
}
.explorer-head .ws{color:var(--faint);text-transform:none;letter-spacing:.02em}
.tree-root-comment{
  font-family:var(--font-mono);font-size:.62rem;color:#8a98a6;
  padding:4px 6px 10px;border-bottom:1px solid var(--hairline);margin-bottom:6px;line-height:1.4
}
.tree-folder{margin-bottom:2px}
.folder-row{
  appearance:none;width:100%;background:transparent;border:none;cursor:pointer;text-align:left;
  display:flex;align-items:center;gap:7px;padding:6px 6px;border-radius:6px;
  font-family:var(--font-mono);font-size:.68rem;font-weight:700;letter-spacing:.02em;
  transition:background .15s
}
.folder-row:hover{background:rgba(255,255,255,.03)}
.folder-row:focus-visible{outline:2px solid var(--accent);outline-offset:-2px}
.folder-row .caret{font-size:.6rem;transition:transform .2s var(--ease);display:inline-block}
.tree-folder.is-collapsed .caret{transform:rotate(-90deg)}
/* THREE folders, one on-brand hue each (AA on the #0d0f12 editor body) —
   the three canonical strata: blocks (wine) · utilities (blue) · solutions (yellow) */
.folder-row .fname--blocks{color:#d99aa1}     /* wine — building blocks */
.folder-row .fname--utilities{color:#79c0ff}  /* blue — utilities */
.folder-row .fname--solutions{color:#ffda19}  /* signal yellow — solutions */
.folder-children{display:flex;flex-direction:column;overflow:hidden;transition:max-height .26s var(--ease),opacity .2s var(--ease);max-height:600px;opacity:1}
.tree-folder.is-collapsed .folder-children{max-height:0;opacity:0}

.tree-leaf{
  position:relative;display:block;text-decoration:none;color:inherit;
  padding:7px 8px 9px 22px;border-radius:6px;margin-left:8px;cursor:pointer;
  transition:background .15s var(--ease)
}
.tree-leaf:hover{background:rgba(255,255,255,.04)}
/* diff-gutter "+" staged beat */
.tree-leaf::before{
  content:'+';position:absolute;left:6px;top:7px;
  font-family:var(--font-mono);font-size:.74rem;font-weight:700;color:#56d364;
  opacity:0;transform:translateX(-4px);transition:opacity .18s var(--ease),transform .18s var(--ease)
}
.tree-leaf:hover::before{opacity:1;transform:none}
.leaf-line{display:flex;align-items:center;gap:7px}
.leaf-glyph{font-family:var(--font-mono);font-size:.66rem;opacity:.55;flex-shrink:0}
.leaf-name{font-family:var(--font-mono);font-size:.74rem;font-weight:500;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
/* leaf-name tint = the folder hue, one step brighter for AA on dark */
.tree-folder[data-cat="blocks"] .leaf-name{color:#e6adb3}
.tree-folder[data-cat="utilities"] .leaf-name{color:#a5d6ff}
.tree-folder[data-cat="solutions"] .leaf-name{color:#ffe45c}
.leaf-tag{font-family:var(--font-mono);font-size:.52rem;color:var(--muted);letter-spacing:.06em;flex-shrink:0}
/* TREE-ONLY catalog: each leaf carries its one-line description INLINE,
   always visible (not hover-only) so the tree reads as a real catalog. */
.leaf-desc{
  font-family:var(--font-mono);font-size:.6rem;color:#8a98a6;line-height:1.4;
  padding-left:23px;margin-top:3px;display:block
}
.tree-leaf[aria-current="true"]{background:rgba(255,255,255,.05)}
.tree-leaf[aria-current="true"] .leaf-name{color:var(--accent)!important}
.tree-leaf:focus-visible{outline:2px solid var(--accent);outline-offset:-2px}

/* RIGHT — PREVIEW pane */
.ide-preview{display:flex;flex-direction:column;min-width:0}
/* file-tab strip — visible only in SITE mode (deployed sites) */
.preview-tabs{
  display:flex;align-items:stretch;background:#15181c;border-bottom:1px solid var(--hairline);
  overflow-x:auto;scrollbar-width:none;flex-shrink:0
}
.preview-tabs::-webkit-scrollbar{display:none}
.ide-preview[data-mode="lib"] .preview-tabs{display:none} /* libraries: no site tab strip */
.editor-tab{
  appearance:none;background:transparent;border:none;cursor:pointer;
  font-family:var(--font-mono);font-size:.62rem;color:rgba(201,209,217,.55);
  padding:9px 14px;display:inline-flex;align-items:center;gap:8px;
  border-right:1px solid var(--hairline);border-bottom:2px solid transparent;
  transition:color .16s,background .16s,border-color .16s;white-space:nowrap;flex-shrink:0
}
.editor-tab:hover{color:var(--muted);background:rgba(255,255,255,.025)}
.editor-tab[aria-selected="true"]{color:var(--ink);background:rgba(255,255,255,.04);border-bottom-color:var(--muted)}
.editor-tab:focus-visible{outline:2px solid var(--accent);outline-offset:-2px}
.editor-tab .close-dot{width:7px;height:7px;border-radius:50%;background:var(--hairline-strong);flex-shrink:0;transition:background .16s}
.editor-tab[aria-selected="true"] .close-dot{background:var(--accent)} /* "modified" dot — the lit yellow stamp */

/* browser-chrome PREVIEW frame */
.preview-stage{flex:1;display:flex;flex-direction:column;padding:16px 18px 0;min-height:0}
.preview-breadcrumb{
  font-family:var(--font-mono);font-size:.58rem;color:var(--muted);letter-spacing:.03em;
  padding:0 2px 10px
}
.preview-breadcrumb b{color:var(--ink);font-weight:700}
.browser-frame{
  flex:1;display:flex;flex-direction:column;border-radius:10px;overflow:hidden;
  border:1px solid var(--hairline-strong);background:#080c10;min-height:0;
  box-shadow:0 12px 40px rgba(0,0,0,.5)
}
.browser-frame[hidden]{display:none}
.browser-chrome{
  display:flex;align-items:center;gap:9px;padding:9px 13px;flex:0 0 auto;
  background:#14181d;border-bottom:1px solid var(--hairline)
}
.browser-chrome .lights{display:flex;gap:6px}
.browser-chrome .lights i{width:9px;height:9px;border-radius:999px;background:var(--hairline-strong)}
.browser-chrome .url{
  flex:1;font-family:var(--font-mono);font-size:.62rem;color:var(--muted);
  background:rgba(230,237,243,.05);padding:5px 11px;border-radius:7px;
  border:1px solid var(--hairline);white-space:nowrap;overflow:hidden;text-overflow:ellipsis
}
.browser-chrome .live{
  font-family:var(--font-mono);font-size:.54rem;letter-spacing:.14em;text-transform:uppercase;
  color:var(--muted);display:inline-flex;align-items:center;gap:6px;flex-shrink:0
}
.browser-chrome .live .pulse{width:7px;height:7px;border-radius:999px;background:var(--accent);animation:livePulse 1.8s ease-in-out infinite}
