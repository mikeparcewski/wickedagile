---
/**
 * Shipped.astro — "experiments." · wicked-crew is the governed BOX around the loop.
 *
 * Layering, top to bottom: wicked-crew (the labeled purple FRAME — the harness
 * of your harnesses, the box the whole loop runs inside) → the LOOP the "current"
 * flows around → a full-width wicked-interactive BAR directly under the center
 * preview pane. wicked-interactive is NOT part of the governed loop: it's a
 * DIFFERENT collaboration mode (real-time, human-in-the-creative-loop — describe
 * it, watch it build, point to refine), a foil to crew's governed autonomy.
 * wicked-bus is the FABRIC beneath the track.
 *
 * The loop (inside crew) is a STADIUM (two straights + two semicircular caps)
 * drawn in an SVG viewBox (240×100); the orbit box shares that 2.4:1 aspect so
 * the SVG scales uniformly. Geometry is computed at BUILD TIME (no runtime trig).
 * The travelling "current" pulse is driven by shipped.js along #ringPath
 * (getPointAtLength) — it auto-plays the selection around the loop (crew's frame
 * gets a govern-purple "running" glow) until the visitor takes control, and
 * parks statically under prefers-reduced-motion.
 *
 * Five inner selectable stations (garden/estate/brain/testing/bus) + the crew
 * frame + the interactive bar all carry data-idx + data-mode + data-preview/
 * data-lib, so shipped.js drives the reused preview pane (showSite / showLib /
 * wipeSlot) unchanged. Five products are live sites (garden · estate · testing ·
 * crew · interactive) → real screenshots; brain + bus (no site) render distinct
 * faux source cards. Below ~880px it falls back to a vertical loop wrapped by a
 * crew header (.shipped-mobile).
 */

// ── MOBILE fallback: the seven packages in LOOP-ROLE (cycle) order. ──────────
const packages = [
  { name: 'wicked-garden', role: 'Steer', color: '#ffda19', lang: 'JS', site: 'wg.wickedagile.com', href: 'https://wg.wickedagile.com', shot: '/screenshots/wicked-garden.png', desc: "Steering before execution — reads each prompt's work-shape + risk and applies the right rigor, plus the capabilities a planner-executor can't do alone." },
  { name: 'wicked-estate', role: 'Equip', color: '#79c0ff', lang: 'RS', site: 'we.wickedagile.com', href: 'https://we.wickedagile.com', shot: '/screenshots/wicked-estate.png', desc: 'Your live technical environment, queryable — requirements↔implementation, blast-radius, infra + policy relationships, operational history.' },
  { name: 'wicked-brain', role: 'Equip', color: '#79c0ff', lang: 'JS', href: 'https://github.com/mikeparcewski/wicked-brain', desc: 'Memory + code-graph with provenance — search, challenge, correct, trace to source.' },
  { name: 'wicked-testing', role: 'Verify', color: '#56d364', lang: 'JS', site: 'wt.wickedagile.com', href: 'https://wt.wickedagile.com', shot: '/screenshots/wicked-testing.png', desc: 'No agent grades its own homework — an enforced wall between the agent that runs the tests and the one that judges them.' },
  { name: 'wicked-crew', role: 'Govern', color: '#d2a8ff', lang: 'JS', site: 'wc.wickedagile.com', href: 'https://wc.wickedagile.com', shot: '/screenshots/wicked-crew.png', desc: 'The control room for governed agent delivery — drive, gate, audit; the human stays in command. The harness for your agent harnesses.' },
  { name: 'wicked-bus', role: 'Fabric', color: '#9aa7b3', lang: 'JS', href: 'https://github.com/mikeparcewski/wicked-bus', desc: 'The durable nervous system beneath it all — local-first, at-least-once, replayable. The fabric the loop rides on.' },
  { name: 'wicked-interactive', role: 'Surface', color: '#f0a868', lang: 'JS', site: 'wi.wickedagile.com', href: 'https://wi.wickedagile.com', shot: '/screenshots/wicked-interactive.png', desc: "A surface beside — composes the family's building blocks; it does not close the loop. Describe it, watch it build, ship HTML/PDF/deck." },
];

// ── STADIUM (racetrack) geometry — build-time, in SVG viewBox units ──────────
const VB_W = 240, VB_H = 100;                         // viewBox; orbit box aspect = 2.4
const TOP = 15, BOT = 85, CAPR = 35;                  // straights + cap radius ((BOT-TOP)/2)
const LCAP = 45, RCAP = 195;                          // cap centers; extremes at 10 / 230
const pct = (x, y) => ({ x: +(x / VB_W * 100).toFixed(2), y: +(y / VB_H * 100).toFixed(2) });

// INNER stations ON the track (clockwise). crew is NO LONGER a station — it is
// the governed BOX around the loop (below). Five inner stations remain; four
// are live sites (garden/estate/testing drive a real screenshot preview), bus +
// brain are the two no-site products (faux source cards, made distinct).
const stations = [
  { key: 'wicked-garden',  short: 'garden',  role: 'Steer',  color: '#ffda19', tint: '#ffe45c', vx: 95,  vy: TOP, idx: 0, mode: 'site', preview: '1', href: 'https://wg.wickedagile.com', glyph: 'JS' },
  { key: 'wicked-estate',  short: 'estate',  role: 'Equip',  color: '#79c0ff', tint: '#a5d6ff', vx: 145, vy: TOP, idx: 1, mode: 'site', preview: '2', href: 'https://we.wickedagile.com', glyph: 'RS' },
  { key: 'wicked-brain',   short: 'brain',   role: 'Equip',  color: '#79c0ff', tint: '#a5d6ff', vx: 195, vy: TOP, idx: 2, mode: 'lib', href: 'https://github.com/mikeparcewski/wicked-brain', glyph: 'JS' },
  { key: 'wicked-testing', short: 'testing', role: 'Verify', color: '#56d364', tint: '#7ee787', vx: 170, vy: BOT, idx: 3, mode: 'site', preview: '3', href: 'https://wt.wickedagile.com', glyph: 'JS' },
  { key: 'wicked-bus',     short: 'bus',     role: 'Fabric', color: '#9aa7b3', tint: '#b6c2ce', vx: 120, vy: BOT, idx: 5, mode: 'lib', href: 'https://github.com/mikeparcewski/wicked-bus', glyph: 'JS', track: true },
].map((s) => ({ ...s, pos: pct(s.vx, s.vy) }));

// Soft (non-package) waypoints — dimmer, smaller, not selectable. (harness = the
// external CLIs crew wraps — nicely, it sits INSIDE crew's box.)
const waypoints = [
  { label: 'intent', ...pct(LCAP, TOP) },              // top-left junction
  { label: 'harness', sub: 'claude · codex · cursor', ...pct(230, 50) }, // right cap apex
  { label: 'record', ...pct(10, 50) },                 // left cap apex
];

// wicked-crew — the governed BOX around the whole loop. Still SELECTABLE via its
// frame legend (drives its own wc. site preview). idx 4 / mode site / preview 4.
const crew = {
  key: 'wicked-crew', role: 'Govern', color: '#d2a8ff', tint: '#e2c5ff',
  idx: 4, mode: 'site', preview: '4', href: 'https://wc.wickedagile.com',
};

// wicked-interactive — a DIFFERENT collaboration mode (real-time, creative-loop):
// a full-width bar UNDER the center preview, inside crew's box but not in the
// governed loop. Selectable → its wi. site preview.
const surface = {
  key: 'wicked-interactive', role: 'Surface', color: '#f0a868',
  idx: 6, mode: 'site', preview: '0', href: 'https://wi.wickedagile.com',
};

// paths (viewBox units) — the track drives both the stroke and the pulse
const trackPath = `M${LCAP},${TOP} L${RCAP},${TOP} A${CAPR},${CAPR} 0 0 1 ${RCAP},${BOT} L${LCAP},${BOT} A${CAPR},${CAPR} 0 0 1 ${LCAP},${TOP} Z`;
const returnPath = `M10,50 A${CAPR},${CAPR} 0 0 1 ${LCAP},${TOP}`; // record → intent (left cap)

// MOBILE derived sets: interactive (a different mode) sits above, crew wraps, the rest are the loop.
const loopPkgs = packages.filter((p) => p.name !== 'wicked-crew' && p.name !== 'wicked-interactive');
const crewPkg = packages.find((p) => p.name === 'wicked-crew');
const surfacePkg = packages.find((p) => p.name === 'wicked-interactive');
---

<!-- ════════════════════════════════════════════════════════════════
     SHIPPED — "experiments." · crew is the governed BOX around the loop.
     Layering: wicked-crew (the frame) → the loop the "current" flows around →
     a full-width wicked-interactive BAR under the center preview (a different
     collaboration mode, not the governed loop). wicked-bus is the fabric beneath.
     ════════════════════════════════════════════════════════════════ -->
<section class="zoneB-section snap-section" id="projects">
  <div class="orbit-shell">
    <!-- compact header (no big multi-line thesis — that caused the overflow) -->
    <div class="orbit-head">
      <span class="zone-kicker">WORKSPACE · 7 PACKAGES · 5 DEPLOYED · ONE LOOP</span>
      <h2 class="zone-title">experiments.</h2>
      <p class="orbit-caption">You cannot stabilize the harness — so the durable system sits <b>around</b> it.</p>
    </div>

    <!-- ── crew: THE GOVERNED BOX the whole loop runs inside ──────────── -->
    <div class="crew-wrap">
      <div class="crew-box" id="crewBox">
        <!-- crew frame legend (IDE-window titlebar) — clickable → crew's preview -->
        <a class="crew-bar" href={crew.href} target="_self" rel="noopener"
           data-idx={crew.idx} data-mode={crew.mode} data-preview={crew.preview}
           data-role={crew.role} data-color={crew.color}
           aria-label="wicked-crew — Govern · the harness of your harnesses, the box the whole loop runs inside (click to preview)">
          <span class="crew-dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="crew-title">wicked-crew <span class="ct-sep" aria-hidden="true">·</span> <b>the harness of your harnesses</b></span>
          <span class="crew-role">GOVERN</span>
        </a>

        <div class="crew-body">
          <!-- ── THE LOOP (inside crew) ──────────────────────────────── -->
          <div class="orbit-wrap">
            <div class="orbit" role="group" aria-label="The wicked loop, governed by wicked-crew: intent, then Steer (wicked-garden), Equip (wicked-estate, wicked-brain), the coding-agent harness, then Verify (wicked-testing), riding the wicked-bus fabric, and record — back to intent.">
              <!-- track + arcs + travelling pulse (viewBox units) -->
              <svg class="orbit-svg" viewBox="0 0 240 100" preserveAspectRatio="xMidYMid meet" aria-hidden="true" focusable="false">
                <!-- the wicked-bus fabric = the loop track itself -->
                <path class="orbit-ring-glow" d={trackPath} />
                <path id="ringPath" class="orbit-ring" d={trackPath} />
                <!-- ↺ return arc: record → intent -->
                <path class="orbit-return" d={returnPath} />
                <text class="orbit-return-mark" x={20.3} y={25.3} text-anchor="middle" dominant-baseline="central">↺</text>
                <!-- the "current": a glowing dash driven by shipped.js along #ringPath
                     (getPointAtLength). It walks the auto-play selection station→station
                     and pins/parks on interaction + prefers-reduced-motion. -->
                <circle class="orbit-pulse-glow" cx="95" cy="15" r="6"></circle>
                <circle class="orbit-pulse" cx="95" cy="15" r="2.4"></circle>
              </svg>

              <!-- soft waypoints (narrative, not selectable) -->
              {waypoints.map((w) => (
                <span class="orbit-waypoint" style={`left:${w.x}%;top:${w.y}%`}>
                  <span class="wp-label">{w.label}</span>
                  {w.sub && <span class="wp-sub">{w.sub}</span>}
                </span>
              ))}

              <!-- inner stations (selectable — drive the center preview) -->
              {stations.map((s) => (
                <a
                  class:list={["orbit-station", s.track && "orbit-station--track"]}
                  href={s.href}
                  target={s.mode === 'site' ? '_self' : '_blank'}
                  rel="noopener"
                  style={`left:${s.pos.x}%;top:${s.pos.y}%;--role:${s.color};--role-tint:${s.tint}`}
                  data-idx={s.idx}
                  data-mode={s.mode}
                  data-preview={s.preview}
                  data-lib={s.mode === 'lib' ? s.key : undefined}
                  data-role={s.role}
                  data-color={s.color}
                  data-vx={s.vx}
                  data-vy={s.vy}
                  aria-label={`${s.key} — ${s.role}`}
                >
                  <span class="st-dot" aria-hidden="true"></span>
                  <span class="st-name">{s.short}</span>
                  <span class="st-role">{s.role}</span>
                </a>
              ))}

              <!-- ── CENTER: the REUSED preview pane (big landscape) ──────────── -->
        <div class="orbit-center" id="workspacePane">
          <div class="ide-preview" id="idePreview" data-mode="site">
            <div class="center-titlebar">
              <span class="ct-name" id="crumbName">wicked-garden</span>
              <span class="ct-role" id="centerRole" style="color:#ffda19">Steer</span>
            </div>

            <div class="preview-stage" id="previewPanel">
              <!-- MODE (a): SITE — browser-frame (shown at init; garden site) -->
              <div class="browser-frame" id="browserFrame">
                <div class="browser-chrome">
                  <span class="lights" aria-hidden="true"><i></i><i></i><i></i></span>
                  <span class="url" id="previewUrl">wg.wickedagile.com</span>
                  <span class="live"><span class="pulse" aria-hidden="true"></span>Live</span>
                </div>
                <div class="browser-shot" id="browserShot">
                  <div class="shot-bg shot-bg-back"></div>
                  <div class="shot-bg shot-bg-front" style="background-image:url('/screenshots/wicked-garden.png')"></div>
                </div>
              </div>

              <!-- MODE (b): LIBRARY — faux code-editor card (hidden at init) -->
              <div class="code-card" id="codeCard" aria-hidden="true" hidden>
                <div class="code-card-chrome">
                  <span class="cc-glyph" aria-hidden="true">JS</span>
                  <span class="cc-file" id="codeFile">wicked-brain.js</span>
                  <span class="cc-badge">read-only</span>
                </div>
                <div class="code-card-body">
                  <pre class="code-block" id="codeBlock"><code></code></pre>
                </div>
              </div>
            </div>

            <div class="preview-readout">
              <div class="readout-desc" id="readoutDesc">Steering before execution — reads each prompt's work-shape + risk and applies the right rigor, plus the capabilities a planner-executor can't do alone.</div>
              <a class="readout-cta" id="readoutCta" href="https://wg.wickedagile.com">Open ↗</a>
            </div>
          </div>
              </div>{/* .orbit-center */}
            </div>{/* .orbit */}
          </div>{/* .orbit-wrap */}

          <!-- wicked-interactive — a FULL-WIDTH bar directly UNDER the center
               preview pane. Not part of the governed loop: it's a DIFFERENT
               collaboration mode — real-time, human-in-the-creative-loop.
               Clickable → its wi. site preview (reuses showSite / data-idx). -->
          <a class="surface-strip" href={surface.href} target="_self" rel="noopener"
             data-idx={surface.idx} data-mode={surface.mode} data-preview={surface.preview}
             data-role={surface.role} data-color={surface.color}
             aria-label="wicked-interactive — a different way to work with agents: describe it, watch it build, point to refine (click to preview)">
            <span class="ss-dot" aria-hidden="true"></span>
            <span class="ss-label"><b>wicked-interactive</b> <span class="ss-sep" aria-hidden="true">·</span> a different way to work with agents — describe it, watch it build, point to refine</span>
            <span class="ss-tag">try it ↗</span>
          </a>
        </div>{/* .crew-body */}
      </div>{/* .crew-box */}
    </div>{/* .crew-wrap */}

    <!-- auto-play affordance: signals the loop is self-playing + lets the visitor
         take control / resume (matches the pattern on the other family sites).
         shipped.js toggles .is-paused + the label. Hidden under reduced motion. -->
    <button class="orbit-autoplay" id="autoplayToggle" type="button" aria-live="polite">
      <span class="ap-dot" aria-hidden="true"></span>
      <span class="ap-text">auto-playing · click any station to drive</span>
    </button>

    <!-- MOBILE (≤880): wicked-interactive (a different collaboration mode) on top,
         then wicked-crew as the labeled wrapper around the vertical loop. -->
    <div class="shipped-mobile" aria-label="wicked-crew and the loop it governs (vertical)">
      <!-- interactive — a different way to work with agents (real-time creative loop) -->
      <a class="shm-surface" href={surfacePkg.href} target="_self" rel="noopener" style={`--role:${surfacePkg.color}`}>
        <span class="shm-dot" aria-hidden="true"></span>
        <span class="shm-surface-label"><b>wicked-interactive</b> · a different way to work with agents — describe it, watch it build, point to refine</span>
        <span class="shm-badge shm-badge--live"><span class="shm-live-dot" aria-hidden="true"></span>live ↗</span>
      </a>

      <!-- crew — the governed box; the loop runs inside it -->
      <div class="shm-crew" style={`--role:${crewPkg.color}`}>
        <a class="shm-crew-head" href={crewPkg.href} target="_self" rel="noopener">
          <span class="shm-crew-dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="shm-crew-name">wicked-crew</span>
          <span class="shm-crew-tag">the harness of your harnesses</span>
          <span class="shm-crew-role">GOVERN ↗</span>
        </a>
        <div class="shm-loop">
          <div class="shm-node shm-node--soft"><span class="shm-soft-label">intent</span></div>
          {loopPkgs.map((p) => (
            <>
              <div class="shm-arrow" aria-hidden="true">↓</div>
              <a class={`shm-item${p.shot ? ' has-shot' : ''}`} href={p.href} target={p.shot ? '_self' : '_blank'} rel="noopener" style={`--role:${p.color}`}>
                <div class="shm-row">
                  <span class="shm-dot" aria-hidden="true"></span>
                  <span class="shm-idx">{p.role}</span>
                  <span class="shm-name">{p.name}</span>
                  {p.site
                    ? (<span class="shm-badge shm-badge--live"><span class="shm-live-dot" aria-hidden="true"></span>live</span>)
                    : (<span class="shm-badge">{p.lang}</span>)}
                </div>
                {p.shot && (<div class="shm-shot" style={`background-image:url('${p.shot}')`}></div>)}
                <div class="shm-desc">{p.desc}</div>
                {p.site && (<div class="shm-url">{p.site} ↗</div>)}
              </a>
            </>
          ))}
          <div class="shm-arrow shm-arrow--return" aria-hidden="true">↺</div>
          <div class="shm-node shm-node--soft"><span class="shm-soft-label">record → intent</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
/* ══════════════════════════════════════════════════════════════════
   SHIPPED — THE LOOP (living orbit)
   Reuses the hero editor conceit: #0d0f12 pane, 12px radius, 0 32px 80px
   shadow, var(--font-mono), the loop-role colors. Theme-aware ground
   (tokens); the center editor pane stays dark in both themes (matches the
   hero terminal). The loop is the dominant element of the section.
   ══════════════════════════════════════════════════════════════════ */

/* the section fills ONE snapped viewport and centers the loop, like the hero. */
.zoneB-section{
  border-top:1px solid var(--hairline);
  min-height:100svh;
  scroll-margin-top:var(--topbar-h);
  display:flex;flex-direction:column;justify-content:center;align-items:center;
  /* symmetric padding + centering keeps the loop inside the visible band under
     the fixed topbar (an asymmetric topbar-sized pad would push it off-screen). */
  padding:18px 24px 14px;
  overflow:hidden; /* safety net: the loop is tuned to fit, never scroll */
}
.orbit-shell{
  width:100%;max-width:1320px;margin:0 auto;
  display:flex;flex-direction:column;align-items:center;
  gap:clamp(4px,1.2vh,14px)
}

/* ── COMPACT HEADER ────────────────────────────────────────────── */
.orbit-head{display:flex;flex-direction:column;align-items:center;gap:clamp(3px,.8vh,8px);text-align:center}
.orbit-head .zone-kicker{justify-content:center}
.orbit-head .zone-kicker::before,
.orbit-head .zone-kicker::after{content:'';width:18px;height:1px;background:var(--hairline-strong)}
.zone-title{
  font-family:var(--font-display);font-weight:900;font-stretch:125%;
  font-size:clamp(1.9rem,3.2vw,2.9rem);color:var(--ink);
  line-height:.9;letter-spacing:-.03em;margin:0
}
.orbit-caption{
  font-family:var(--font-sans,inherit);font-size:clamp(.8rem,1.1vw,.94rem);
  line-height:1.4;color:var(--muted);margin:0;max-width:62ch
}
.orbit-caption b{color:var(--ink);font-weight:700}

/* ── wicked-interactive — a FULL-WIDTH bar directly UNDER the center preview,
     inside crew's box. A DIFFERENT collaboration mode (real-time, creative-loop),
     not part of the governed loop. Spans the full loop-area width. ─ */
.surface-strip{
  display:flex;align-items:center;gap:10px;width:100%;
  margin-top:clamp(6px,1vw,14px);
  font-family:var(--font-mono);font-size:.62rem;text-decoration:none;color:var(--muted);
  border:1px dashed color-mix(in oklab,#f0a868 45%,var(--hairline));border-radius:8px;
  padding:8px 15px;background:linear-gradient(color-mix(in oklab,#f0a868 7%,transparent),transparent);
  transition:border-color .18s var(--ease),box-shadow .22s var(--ease),background .18s
}
.surface-strip .ss-dot{width:8px;height:8px;border-radius:50%;background:#f0a868;box-shadow:0 0 8px -1px #f0a868;flex-shrink:0}
.surface-strip .ss-label{flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.surface-strip .ss-label b{color:#f6bd8a;font-weight:700}
.surface-strip .ss-sep{opacity:.5;margin:0 2px}
.surface-strip .ss-tag{font-size:.55rem;letter-spacing:.06em;text-transform:uppercase;font-weight:700;color:#f0a868;flex-shrink:0}
.surface-strip:hover{border-color:#f0a868;background:linear-gradient(color-mix(in oklab,#f0a868 12%,transparent),transparent)}
.surface-strip:focus-visible{outline:none;border-color:#f0a868;box-shadow:0 0 0 2px color-mix(in oklab,#f0a868 55%,transparent)}
.surface-strip[aria-current="true"]{
  border-style:solid;border-color:#f0a868;
  box-shadow:0 0 0 1px color-mix(in oklab,#f0a868 40%,transparent),0 0 28px -8px #f0a868
}

/* ── crew: THE GOVERNED BOX around the loop ────────────────────────── */
.crew-wrap{width:100%;display:flex;justify-content:center;position:relative}
.crew-box{
  position:relative;width:fit-content;max-width:100%;
  border:1.5px solid color-mix(in oklab,#d2a8ff 42%,var(--hairline));border-radius:14px;
  background:linear-gradient(color-mix(in oklab,#d2a8ff 5%,transparent),transparent 62%);
  box-shadow:0 0 0 1px color-mix(in oklab,#d2a8ff 10%,transparent),0 24px 60px -32px rgba(0,0,0,.65);
  overflow:hidden;transition:border-color .4s var(--ease),box-shadow .4s var(--ease)
}
/* auto-play running → gentle govern-purple pulse on the frame */
.crew-box.is-running{animation:crewRun 3.6s ease-in-out infinite}
@keyframes crewRun{
  0%,100%{box-shadow:0 0 0 1px color-mix(in oklab,#d2a8ff 16%,transparent),0 0 30px -14px #d2a8ff,0 24px 60px -32px rgba(0,0,0,.65)}
  50%{box-shadow:0 0 0 1px color-mix(in oklab,#d2a8ff 30%,transparent),0 0 52px -6px #d2a8ff,0 24px 60px -32px rgba(0,0,0,.65)}
}
/* crew frame legend = an IDE-window titlebar; the whole bar selects crew */
.crew-bar{
  display:flex;align-items:center;gap:10px;text-decoration:none;
  padding:8px 15px;background:color-mix(in oklab,#d2a8ff 11%,#14181d);
  border-bottom:1px solid color-mix(in oklab,#d2a8ff 30%,var(--hairline));
  transition:background .16s
}
.crew-bar:hover{background:color-mix(in oklab,#d2a8ff 17%,#14181d)}
.crew-bar:focus-visible{outline:2px solid #d2a8ff;outline-offset:-2px}
.crew-bar .crew-dots{display:flex;gap:5px;flex-shrink:0}
.crew-bar .crew-dots i{width:9px;height:9px;border-radius:50%;background:color-mix(in oklab,#d2a8ff 55%,transparent)}
.crew-bar .crew-title{
  flex:1;min-width:0;font-family:var(--font-mono);font-size:.72rem;color:var(--ink);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis
}
.crew-bar .crew-title b{color:#e2c5ff;font-weight:700}
.crew-bar .ct-sep{opacity:.5;margin:0 2px}
.crew-bar .crew-role{
  font-family:var(--font-mono);font-size:.56rem;letter-spacing:.16em;text-transform:uppercase;
  font-weight:700;color:#d2a8ff;flex-shrink:0
}
.crew-bar[aria-current="true"]{background:color-mix(in oklab,#d2a8ff 22%,#14181d)}
.crew-bar[aria-current="true"] .crew-dots i:first-child{background:#d2a8ff;box-shadow:0 0 8px 0 #d2a8ff}
.crew-body{padding:clamp(6px,1vw,16px)}

/* ── THE LOOP (wide racetrack, inside crew's box) ──────────────── */
.orbit-wrap{position:relative;display:flex;justify-content:center}
.orbit{
  position:relative;
  /* width is the driver; height follows the 2.4:1 aspect. Bounded by BOTH
     viewport width and height — smaller than a full-bleed loop since it sits
     INSIDE crew's box (a titlebar above, the full-width interactive bar below).
     The 52vh term caps the loop HEIGHT so the interior clears the station rows. */
  --loop-w:min(90vw, 2.4 * 52vh, 1080px);
  width:var(--loop-w);aspect-ratio:2.4;
  overflow:visible;flex:0 0 auto;
  /* size container so the center pane can be sized in % of the LOOP box (cqw/cqh)
     — it then always clears the station rows, at any viewport, with no overlap. */
  container-type:size
}
.orbit-svg{position:absolute;inset:0;width:100%;height:100%;overflow:visible;pointer-events:none;z-index:1}

/* the wicked-bus fabric = the loop track */
.orbit-ring{
  fill:none;stroke:#9aa7b3;stroke-width:.9;stroke-linecap:round;
  stroke-dasharray:2.6 4;opacity:.55;
  animation:fabricFlow 6s linear infinite
}
.orbit-ring-glow{fill:none;stroke:#9aa7b3;stroke-width:4.5;opacity:.09;filter:blur(1px)}
@keyframes fabricFlow{to{stroke-dashoffset:-66}}
/* ↺ return arc: record → intent */
.orbit-return{fill:none;stroke:var(--accent);stroke-width:1;stroke-linecap:round;stroke-dasharray:.3 4;opacity:.8}
.orbit-return-mark{fill:var(--accent);font-size:7px;font-family:var(--font-mono);opacity:.9}
/* the travelling current */
.orbit-pulse{fill:#fff}
.orbit-pulse-glow{fill:var(--accent);opacity:.5;filter:blur(2px)}

/* ── STATIONS ──────────────────────────────────────────────────── */
.orbit-station{
  position:absolute;transform:translate(-50%,-50%);z-index:4;
  display:inline-flex;align-items:center;gap:8px;
  padding:8px 14px 8px 11px;border-radius:999px;text-decoration:none;
  background:linear-gradient(#14181d,#0f1216);
  border:1px solid var(--hairline-strong);
  box-shadow:0 8px 22px rgba(0,0,0,.5);
  font-family:var(--font-mono);white-space:nowrap;cursor:pointer;
  transition:transform .18s var(--ease),border-color .18s var(--ease),box-shadow .22s var(--ease),background .18s
}
.orbit-station .st-dot{
  width:9px;height:9px;border-radius:50%;flex-shrink:0;
  background:var(--role);box-shadow:0 0 8px -1px var(--role)
}
.orbit-station .st-name{font-size:.82rem;font-weight:700;color:var(--role-tint);letter-spacing:.01em}
.orbit-station .st-role{
  font-size:.54rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);
  padding-left:8px;border-left:1px solid var(--hairline-strong)
}
.orbit-station:hover,
.orbit-station:focus-visible{
  transform:translate(-50%,-50%) scale(1.06);
  border-color:color-mix(in oklab,var(--role) 55%,transparent);
  box-shadow:0 10px 30px rgba(0,0,0,.55),0 0 0 1px color-mix(in oklab,var(--role) 35%,transparent),0 0 30px -6px var(--role);
  outline:none;z-index:6
}
.orbit-station:focus-visible{box-shadow:0 10px 30px rgba(0,0,0,.55),0 0 0 2px var(--role),0 0 30px -4px var(--role)}
.orbit-station[aria-current="true"]{
  border-color:var(--role);background:linear-gradient(#191d23,#111418);
  box-shadow:0 10px 34px rgba(0,0,0,.6),0 0 0 1px color-mix(in oklab,var(--role) 55%,transparent),0 0 40px -4px var(--role);
  z-index:6
}
.orbit-station[aria-current="true"] .st-dot{box-shadow:0 0 14px 0 var(--role)}
.orbit-station[aria-current="true"] .st-role{color:var(--role-tint)}

/* wicked-bus rides the track: greyer, dashed, reads as part of the fabric */
.orbit-station--track{background:linear-gradient(#12161a,#0d1013);border-style:dashed}
.orbit-station--track .st-name{color:#b6c2ce}

/* ── SOFT WAYPOINTS (narrative) ────────────────────────────────── */
.orbit-waypoint{
  position:absolute;transform:translate(-50%,-50%);z-index:3;
  display:flex;flex-direction:column;align-items:center;gap:2px;
  font-family:var(--font-mono);pointer-events:none;text-align:center
}
.orbit-waypoint .wp-label{
  font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--faint);
  padding:4px 11px;border:1px dashed var(--hairline);border-radius:999px;
  background:rgba(13,15,18,.6);backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px)
}
.orbit-waypoint .wp-sub{font-size:.52rem;letter-spacing:.05em;color:var(--faint);opacity:.85}

/* ── CENTER: the reused preview pane (floats in the loop interior) ──
   Sized in cqw/cqh (% of the LOOP box) + capped in px, so it always clears the
   station rows with breathing room, at any viewport — never overlapping a node.
   Height flows down the flex chain so the shot fills whatever space is left. */
.orbit-center{
  position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);z-index:5;
  width:min(44cqw,440px);height:min(56cqh,300px);
  display:flex
}
.orbit-center .ide-preview{
  flex:1;min-height:0;
  display:flex;flex-direction:column;background:#0d0f12;border-radius:12px;overflow:hidden;
  font-family:var(--font-mono);
  border:1px solid rgba(255,255,255,.06);
  box-shadow:0 32px 80px rgba(0,0,0,.72),0 0 0 1px rgba(255,255,255,.05),
             0 0 70px -18px var(--center-glow,rgba(255,218,25,.4));
  transition:box-shadow .3s var(--ease)
}
.center-titlebar{
  display:flex;align-items:center;justify-content:space-between;gap:8px;
  background:#1a1d21;border-bottom:1px solid rgba(255,255,255,.06);
  padding:8px 13px;flex-shrink:0
}
.center-titlebar .ct-name{font-size:.78rem;font-weight:700;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.center-titlebar .ct-role{font-size:.56rem;letter-spacing:.14em;text-transform:uppercase;font-weight:700;flex-shrink:0}

.preview-stage{flex:1;min-height:0;display:flex;flex-direction:column;padding:12px 13px 0}
.browser-frame{
  flex:1;min-height:0;
  display:flex;flex-direction:column;border-radius:9px;overflow:hidden;
  border:1px solid var(--hairline-strong);background:#080c10;
  box-shadow:0 10px 30px rgba(0,0,0,.5)
}
.browser-frame[hidden]{display:none}
.browser-chrome{
  display:flex;align-items:center;gap:8px;padding:8px 11px;flex:0 0 auto;
  background:#14181d;border-bottom:1px solid var(--hairline)
}
.browser-chrome .lights{display:flex;gap:5px}
.browser-chrome .lights i{width:8px;height:8px;border-radius:999px;background:var(--hairline-strong)}
.browser-chrome .url{
  flex:1;font-family:var(--font-mono);font-size:.58rem;color:var(--muted);
  background:rgba(230,237,243,.05);padding:5px 10px;border-radius:6px;
  border:1px solid var(--hairline);white-space:nowrap;overflow:hidden;text-overflow:ellipsis
}
.browser-chrome .live{
  font-family:var(--font-mono);font-size:.5rem;letter-spacing:.12em;text-transform:uppercase;
  color:var(--muted);display:inline-flex;align-items:center;gap:5px;flex-shrink:0
}
.browser-chrome .live .pulse{width:6px;height:6px;border-radius:999px;background:var(--accent);animation:livePulse 1.8s ease-in-out infinite}
@keyframes livePulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(255,218,25,.55)}50%{opacity:.6;box-shadow:0 0 0 4px rgba(255,218,25,0)}}
.browser-shot{position:relative;flex:1;min-height:0;overflow:hidden;background:#080c10}
/* frame the site around mid-page so it reads as a complete preview, never a
   giant hero headline cropped mid-word */
.shot-bg{position:absolute;inset:0;background-size:cover;background-position:center 52%}
.shot-bg-back{z-index:1}
.shot-bg-front{z-index:2}
.browser-shot::before{
  content:'';position:absolute;inset:0;z-index:5;pointer-events:none;
  background:linear-gradient(160deg,rgba(0,0,0,.06) 0%,transparent 42%,rgba(0,0,0,.4) 100%)
}

/* MODE (b): library faux code-editor card */
.code-card{
  flex:1;min-height:0;
  display:flex;flex-direction:column;border-radius:9px;overflow:hidden;
  border:1px solid var(--hairline-strong);background:#0d0f12;
  box-shadow:0 10px 30px rgba(0,0,0,.5)
}
.code-card[hidden]{display:none}
.code-card-chrome{
  display:flex;align-items:center;gap:8px;padding:8px 11px;flex:0 0 auto;
  background:#14181d;border-bottom:1px solid var(--hairline)
}
.code-card-chrome .cc-glyph{
  font-family:var(--font-mono);font-size:.54rem;font-weight:700;letter-spacing:.04em;
  color:#79c0ff;background:rgba(121,192,255,.12);border-radius:4px;padding:2px 7px;flex-shrink:0
}
.code-card-chrome .cc-file{
  flex:1;font-family:var(--font-mono);font-size:.64rem;color:var(--ink);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis
}
.code-card-chrome .cc-badge{
  font-family:var(--font-mono);font-size:.48rem;letter-spacing:.12em;text-transform:uppercase;
  color:var(--muted);border:1px solid var(--hairline);border-radius:5px;padding:2px 7px;flex-shrink:0
}
.code-card-body{flex:1;min-height:0;overflow:auto;background:#0d0f12}
.code-card-body::-webkit-scrollbar{width:4px;height:4px}
.code-card-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px}
.code-block{margin:0;padding:12px 14px 14px 0;font-family:var(--font-mono);font-size:.7rem;line-height:1.8}
.code-block code{display:block}
.code-line{display:flex;align-items:flex-start;white-space:pre-wrap;word-break:break-word}
.code-line .ln{
  flex:0 0 auto;width:30px;padding-right:12px;text-align:right;user-select:none;
  color:rgba(255,255,255,.22);font-variant-numeric:tabular-nums
}
.code-line .lc{flex:1;min-width:0;color:#c9d1d9}
.code-line .cm{color:#56d364;opacity:.85}
.code-line .kw{color:#ff7b72}
.code-line .st{color:#a5d6ff}
.code-line .fn{color:#d2a8ff}
.code-line .nm{color:#79c0ff}

/* bottom readout — tagline (line-clamped) + CTA */
.preview-readout{
  flex:0 0 auto;display:flex;align-items:center;justify-content:space-between;gap:14px;
  padding:11px 13px 13px;border-top:1px solid var(--hairline)
}
.readout-desc{
  font-family:var(--font-mono);font-size:.64rem;color:#c9d1d9;line-height:1.45;min-width:0;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden
}
.readout-cta{
  font-family:var(--font-mono);font-size:.62rem;font-weight:700;letter-spacing:.05em;
  color:var(--accent);text-decoration:none;white-space:nowrap;flex-shrink:0;
  border-bottom:1px solid rgba(255,218,25,.32);padding-bottom:1px;transition:opacity .15s
}
.readout-cta:hover{opacity:.78}
.readout-cta:focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:2px}

/* ── AUTO-PLAY affordance ──────────────────────────────────────── */
.orbit-autoplay{
  appearance:none;cursor:pointer;align-self:center;margin-top:2px;
  display:inline-flex;align-items:center;gap:8px;
  font-family:var(--font-mono);font-size:.56rem;letter-spacing:.1em;text-transform:uppercase;
  color:var(--muted);background:rgba(255,255,255,.02);
  border:1px solid var(--hairline);border-radius:999px;padding:6px 14px;
  transition:color .16s,border-color .16s,background .16s
}
.orbit-autoplay:hover{color:var(--ink);border-color:var(--hairline-strong);background:rgba(255,255,255,.04)}
.orbit-autoplay:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
.orbit-autoplay .ap-dot{
  width:7px;height:7px;border-radius:50%;flex-shrink:0;background:var(--accent);
  box-shadow:0 0 8px -1px var(--accent);animation:apBlink 1.6s ease-in-out infinite
}
@keyframes apBlink{0%,100%{opacity:1}50%{opacity:.35}}
/* paused: the visitor is driving — the dot goes solid + accent border to resume */
.orbit-autoplay.is-paused{color:var(--ink);border-color:color-mix(in oklab,var(--accent) 40%,transparent)}
.orbit-autoplay.is-paused .ap-dot{animation:none;background:var(--muted);box-shadow:none}

/* ── REDUCED MOTION — freeze the kinetics to a steady state ─────── */
@media(prefers-reduced-motion:reduce){
  .orbit-ring{animation:none;stroke-dashoffset:0}
  .orbit-autoplay .ap-dot,
  .browser-chrome .live .pulse{animation:none}
  .shot-bg-front{transition:none!important}
  .orbit-pulse-glow{opacity:.85}
  .orbit-autoplay{display:none} /* no auto-play to advertise; loop parks on garden */
}

/* ── DESKTOP ↔ MOBILE SWITCH (≤880: the loop can't hold the nodes) ── */
.shipped-mobile{display:none}
@media(max-width:880px){
  .zoneB-section{
    min-height:auto;overflow:visible;
    padding:52px 20px 8px;justify-content:flex-start
  }
  .crew-wrap,
  .orbit-autoplay{display:none} /* the loop + its chrome are desktop-only */
  .orbit-head{align-items:flex-start;text-align:left}
  .orbit-head .zone-kicker{justify-content:flex-start}
  .orbit-head .zone-kicker::after{display:none}
  .orbit-caption{max-width:100%}
  .shipped-mobile{display:flex;flex-direction:column;width:100%;margin-top:18px;gap:10px}
}

/* ── MOBILE: interactive (a different collaboration mode) + crew wrapper + loop ─ */
.shm-surface{
  display:flex;align-items:center;gap:9px;text-decoration:none;color:var(--muted);
  font-family:var(--font-mono);font-size:.66rem;
  border:1px dashed color-mix(in oklab,#f0a868 45%,var(--hairline));border-radius:8px;
  padding:10px 13px;background:linear-gradient(color-mix(in oklab,#f0a868 7%,transparent),transparent)
}
.shm-surface .shm-surface-label{flex:1;min-width:0;line-height:1.4}
.shm-surface .shm-surface-label b{color:#f6bd8a;font-weight:700}
.shm-crew{
  border:1.5px solid color-mix(in oklab,#d2a8ff 40%,var(--hairline));border-radius:12px;overflow:hidden;
  background:linear-gradient(color-mix(in oklab,#d2a8ff 5%,transparent),transparent 60%)
}
.shm-crew-head{
  display:flex;align-items:center;gap:9px;text-decoration:none;color:inherit;flex-wrap:wrap;
  padding:11px 14px;background:color-mix(in oklab,#d2a8ff 12%,#14181d);
  border-bottom:1px solid color-mix(in oklab,#d2a8ff 28%,var(--hairline))
}
.shm-crew-head .shm-crew-dots{display:flex;gap:5px;flex-shrink:0}
.shm-crew-head .shm-crew-dots i{width:8px;height:8px;border-radius:50%;background:color-mix(in oklab,#d2a8ff 55%,transparent)}
.shm-crew-head .shm-crew-name{font-family:var(--font-mono);font-size:.86rem;font-weight:700;color:#e2c5ff}
.shm-crew-head .shm-crew-tag{font-family:var(--font-mono);font-size:.6rem;color:var(--muted);flex:1;min-width:0}
.shm-crew-head .shm-crew-role{font-family:var(--font-mono);font-size:.54rem;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:#d2a8ff;flex-shrink:0}
.shm-loop{display:flex;flex-direction:column;align-items:stretch;gap:0;padding:12px 12px 14px}
.shm-arrow{
  font-family:var(--font-mono);font-size:1rem;color:var(--faint);text-align:center;
  line-height:1;padding:6px 0
}
.shm-arrow--return{color:var(--accent);font-size:1.15rem}
.shm-node--soft{display:flex;justify-content:center}
.shm-soft-label{
  font-family:var(--font-mono);font-size:.56rem;letter-spacing:.14em;text-transform:uppercase;
  color:var(--faint);border:1px dashed var(--hairline);border-radius:999px;padding:5px 13px
}
.shm-item{
  display:block;text-decoration:none;color:inherit;padding:14px 15px;
  border:1px solid var(--hairline);border-left:3px solid var(--role,var(--hairline-strong));
  border-radius:10px;background:rgba(20,24,29,.6);transition:background .15s,border-color .15s
}
.shm-item:active{background:rgba(255,255,255,.03)}
.shm-row{display:flex;align-items:center;gap:9px}
.shm-dot{width:8px;height:8px;border-radius:50%;background:var(--role,var(--muted));flex-shrink:0;box-shadow:0 0 7px -1px var(--role)}
.shm-idx{font-family:var(--font-mono);font-size:.52rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);flex-shrink:0}
.shm-name{font-family:var(--font-mono);font-size:.9rem;font-weight:700;color:#e6edf3;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.shm-badge{font-family:var(--font-mono);font-size:.52rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(201,209,217,.6);border:1px solid rgba(255,255,255,.14);border-radius:5px;padding:2px 7px;flex-shrink:0}
.shm-badge--live{color:#56d364;border-color:rgba(86,211,100,.4);display:inline-flex;align-items:center;gap:5px}
.shm-live-dot{width:6px;height:6px;border-radius:50%;background:#56d364;flex-shrink:0}
.shm-shot{margin-top:11px;aspect-ratio:16/10;border-radius:8px;border:1px solid rgba(255,255,255,.12);background-size:cover;background-position:top center;background-color:#080c10}
.shm-desc{font-family:var(--font-mono);font-size:.68rem;color:#8a98a6;line-height:1.5;margin-top:10px}
.shm-url{font-family:var(--font-mono);font-size:.56rem;letter-spacing:.06em;color:var(--accent);margin-top:8px}
</style>

