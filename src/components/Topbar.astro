---
/**
 * Topbar.astro — fixed nav header. Canonical for the wicked-* family.
 * Markup + CSS ported verbatim. CSS is is:global so the original
 * class names survive and the dropdown / theme scripts still match.
 */
---

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar__inner">
    <a href="https://wickedagile.com" class="wordmark" aria-label="wickedagile">
      <span class="wordmark-mark" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d1117" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l3.5 14L12 8l5.5 11L21 5"/></svg>
      </span>
      <span><span class="wk">wicked</span><span class="ag">agile</span></span>
    </a>
    <nav class="nav">
      <div class="dropdown-wrap" data-tip="ecosystem">
        <button class="icon-btn" id="projectsBtn" aria-label="Browse projects" aria-expanded="false" aria-haspopup="true">
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><rect x=".5" y=".5" width="5" height="5" rx="1.2" fill="currentColor"/><rect x="8.5" y=".5" width="5" height="5" rx="1.2" fill="currentColor"/><rect x=".5" y="8.5" width="5" height="5" rx="1.2" fill="currentColor"/><rect x="8.5" y="8.5" width="5" height="5" rx="1.2" fill="currentColor"/></svg>
        </button>
        <div class="dropdown-menu" id="projectsMenu" hidden>
          <span class="dropdown-kicker">wicked-* ecosystem</span>
          <a href="https://wg.wickedagile.com" target="_blank" rel="noopener" class="dropdown-item">wicked-garden <span class="dropdown-tag">site ↗</span></a>
          <a href="https://wi.wickedagile.com" target="_blank" rel="noopener" class="dropdown-item">wicked-interactive <span class="dropdown-tag">site ↗</span></a>
          <a href="https://we.wickedagile.com" target="_blank" rel="noopener" class="dropdown-item">wicked-estate <span class="dropdown-tag">site ↗</span></a>
          <div class="dropdown-divider"></div>
          <a href="https://github.com/mikeparcewski/wicked-brain" target="_blank" rel="noopener" class="dropdown-item">wicked-brain</a>
          <a href="https://github.com/mikeparcewski/wicked-bus" target="_blank" rel="noopener" class="dropdown-item">wicked-bus</a>
          <a href="https://github.com/mikeparcewski/wicked-testing" target="_blank" rel="noopener" class="dropdown-item">wicked-testing</a>
          <a href="https://github.com/mikeparcewski/wicked-vault" target="_blank" rel="noopener" class="dropdown-item">wicked-vault</a>
          <a href="https://github.com/mikeparcewski/wicked-loom" target="_blank" rel="noopener" class="dropdown-item">wicked-loom</a>
          <a href="https://github.com/mikeparcewski/wicked-understanding" target="_blank" rel="noopener" class="dropdown-item">wicked-understanding</a>
        </div>
      </div>
      <a href="https://medium.com/@mike.parcewski" class="icon-btn" target="_blank" rel="noopener" aria-label="Medium" data-tip="writing">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
      </a>
      <a class="icon-btn" href="https://github.com/mikeparcewski" target="_blank" rel="noopener" aria-label="GitHub" data-tip="github">
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.02-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      <button class="icon-btn" id="themeBtn" aria-label="Toggle theme" data-tip="toggle theme">
        <svg id="themeIcon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></svg>
      </button>
    </nav>
  </div>
</header>

<style is:global>
/* TOPBAR */
.topbar{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--topbar-h);background:rgba(13,17,23,.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--hairline-strong)}
[data-theme="light"] .topbar{background:rgba(24,47,60,.94)}
.topbar__inner{display:flex;align-items:center;justify-content:space-between;height:100%;padding:0 28px;max-width:1240px;margin:0 auto}
.wordmark{display:inline-flex;align-items:center;gap:10px;font-family:var(--font-display);font-weight:900;font-stretch:125%;font-size:1.22rem;letter-spacing:-.01em;color:var(--ink);text-decoration:none}
.wordmark-mark{width:28px;height:28px;border-radius:9px;background:var(--accent);display:grid;place-items:center;flex-shrink:0}
.wordmark .wk{color:var(--ink)}
.wordmark .ag{color:var(--accent)}
.nav{display:flex;align-items:center;gap:12px}
[data-tip]{position:relative}
[data-tip]::after{content:attr(data-tip);position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:rgba(0,0,0,.92);color:#e6edf3;font-family:var(--font-mono);font-size:.6rem;white-space:nowrap;padding:4px 9px;border-radius:5px;border:1px solid var(--hairline-strong);pointer-events:none;opacity:0;transition:opacity .18s;z-index:300}
[data-tip]:hover::after{opacity:1}
.icon-btn{display:inline-grid;place-items:center;width:36px;height:36px;border-radius:999px;border:1px solid var(--hairline-strong);color:var(--ink);background:transparent;cursor:pointer;text-decoration:none;transition:border-color .25s var(--ease),color .25s var(--ease),background .25s var(--ease);padding:0;font-size:inherit;text-transform:none;flex-shrink:0}
.icon-btn:hover{border-color:var(--accent);background:var(--accent);color:var(--accent-ink)}
.icon-btn svg{display:block}
.dropdown-wrap{position:relative}
.dropdown-menu{position:absolute;top:calc(100% + 8px);right:0;z-index:200;min-width:228px;background:var(--surface);border:1px solid var(--hairline-strong);border-radius:12px;padding:6px;box-shadow:0 18px 48px -14px rgba(0,0,0,.7)}
.dropdown-kicker{display:block;font-family:var(--font-mono);font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);padding:7px 10px 5px}
.dropdown-item{display:flex;justify-content:space-between;align-items:center;padding:8px 10px;border-radius:6px;color:var(--ink);font-size:.82rem;text-decoration:none;transition:background .15s,color .15s}
.dropdown-item:hover{background:rgba(255,218,25,.1);color:var(--accent-ink)}
.dropdown-tag{font-family:var(--font-mono);font-size:.6rem;color:var(--faint);letter-spacing:.1em}
.dropdown-divider{height:1px;background:var(--hairline);margin:4px 0}
</style>

<script is:inline>
(function () {
  'use strict';

  /* THEME */
  var SUN = '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
  var MOON = '<path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/>';
  function setTheme(t){document.documentElement.setAttribute('data-theme',t);localStorage.setItem('wa-theme',t);var ic=document.getElementById('themeIcon');if(ic)ic.innerHTML=t==='light'?MOON:SUN}
  /* respect the no-flash init already on <html>, falling back to stored/default */
  setTheme(document.documentElement.getAttribute('data-theme')||localStorage.getItem('wa-theme')||'dark');
  var themeBtn=document.getElementById('themeBtn');
  if(themeBtn)themeBtn.addEventListener('click',function(){setTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark')});

  /* DROPDOWN */
  (function(){
    var btn=document.getElementById('projectsBtn'),menu=document.getElementById('projectsMenu');
    if(!btn||!menu)return;
    btn.addEventListener('click',function(e){e.stopPropagation();var o=!menu.hidden;menu.hidden=o;btn.setAttribute('aria-expanded',!o)});
    document.addEventListener('click',function(){menu.hidden=true;btn.setAttribute('aria-expanded','false')});
    document.addEventListener('keydown',function(e){if(e.key==='Escape'){menu.hidden=true;btn.setAttribute('aria-expanded','false')}});
  })();
})();
</script>
