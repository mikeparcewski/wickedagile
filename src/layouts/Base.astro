---
/**
 * Base.astro — the document shell for wickedagile.com
 *
 * Holds the <head> (meta, fonts, favicon, global stylesheet) and a
 * no-flash theme-init script that reads localStorage 'wa-theme' and
 * sets data-theme BEFORE paint. The theme TOGGLE button lives in
 * Topbar; this layout only prevents the flash.
 *
 * Note: the source has no global film-grain / grid overlay — the only
 * texture (radial grid + accent glow) is scoped to #terminal-section,
 * so it travels with the Hero component, not here.
 */
const {
  title = 'wickedagile — the best code tells a story',
  description = 'Nine local-first tools for AI-native teams.',
} = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0d1117" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
  />
  <!-- no-flash theme init: set data-theme before first paint -->
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('wa-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <slot />
</body>
</html>
